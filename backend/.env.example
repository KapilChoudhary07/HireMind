PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
GEMINI_API_KEY=your_gemini_api_key

# Resend transactional email
RESEND_API_KEY=re_your_api_key

# Use onboarding@resend.dev only for initial testing.
# In production, verify your domain in Resend and use your own sender:
RESEND_FROM_EMAIL=HireMind <noreply@yourdomain.com>
